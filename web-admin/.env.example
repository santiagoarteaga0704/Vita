# Copiá este archivo a .env.local y rellená los valores reales.
# .env.local está en .gitignore, NO lo subas al repo.

# ─── API ───
# Las rutas viven dentro de Next.js en /api/*, mismo origen.
NEXT_PUBLIC_API_URL=/api

# ─── Gemini API (única dependencia remota) ───
# Sacá tu key gratis en https://aistudio.google.com (tier gratuito: 1.500 req/día)
GEMINI_API_KEY=AQ.AbXXXXXXXXXX

# ─── JWT para auth (productores PWA + admin panel) ───
# String random largo (mínimo 20 caracteres). Para producción usar uno único.
JWT_SECRET=vita-hackathon-jwt-secret-cambiar-en-prod-string-largo
JWT_EXPIRES_IN=30d
